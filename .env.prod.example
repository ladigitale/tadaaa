# Copier vers `.env` à la racine (non versionné) avant `docker compose -f compose.prod.yaml up`
# Remplacer example.com par vos domaines réels.

APP_SERVER_NAME=app.example.com
API_SERVER_NAME=api.example.com
ACME_EMAIL=you@example.com

APP_SECRET=change-me-to-a-long-random-string
POSTGRES_DB=tada
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_VERSION=16

CORS_ALLOW_ORIGIN=^https://app\.example\.com$
REGISTRATION_AUTO_APPROVE=0
MCP_ALLOWED_HOSTS=api.example.com

HTTP_PORT=80
HTTPS_PORT=443
HTTP3_PORT=443
