# =============================================================================
# ENV / SECRETS
# -----------------------------------------------------------------------------
# Seul fichier ENV versionné (modèle générique, placeholders) :
#   apps/api/.env
#
# Tout le reste est ignoré : .env, .env.local, .env.dist, .env.prod*,
# .env.*.dist, .env.prod.example, etc.
# Les exemples Compose / prod sont dans .ops/deploy.md (pas de fichier .env*).
# =============================================================================

.env
.env.*
**/.env
**/.env.*

# Unique exception : modèle Symfony générique
!apps/api/.env

# Symfony runtime
apps/api/var/
apps/api/public/bundles/
apps/api/config/secrets/prod/prod.decrypt.private.php

# JWT & certificats (ne jamais publier)
apps/api/config/jwt/*.pem
.ops/certs/
*.pem
!apps/api/config/jwt/.gitkeep

