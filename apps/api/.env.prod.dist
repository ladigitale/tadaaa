# Production — placeholders. Copier vers .env.local sur le serveur (jamais committer les secrets).
# Ou exporter ces variables via Coolify / Docker Compose.

APP_ENV=prod
APP_SECRET=
DEFAULT_URI=https://api.example.com

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://app:CHANGE_ME@database:5432/tada?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https://app\.example\.com$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=
###< lexik/jwt-authentication-bundle ###

###> tadaaa ###
REGISTRATION_AUTO_APPROVE=0
MCP_ALLOWED_HOSTS=api.example.com
###< tadaaa ###
