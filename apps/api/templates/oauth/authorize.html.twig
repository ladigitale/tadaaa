{% extends 'base.html.twig' %}

{% block title %}Authorize MCP — Tadaaa{% endblock %}

{% block stylesheets %}
<style>
  :root {
    color-scheme: light dark;
    --bg: #0f1419;
    --card: #1a222c;
    --text: #e7ecf1;
    --muted: #8b9aab;
    --accent: #3d8bfd;
    --danger: #f07178;
    --border: #2a3542;
  }
  @media (prefers-color-scheme: light) {
    :root {
      --bg: #f4f6f8;
      --card: #fff;
      --text: #1a222c;
      --muted: #5c6b7a;
      --border: #d5dde5;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    min-height: 100vh;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .card {
    width: 100%;
    max-width: 26rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
  }
  h1 { font-size: 1.25rem; margin: 0 0 0.35rem; }
  .brand { font-weight: 700; letter-spacing: -0.02em; }
  p { margin: 0 0 1rem; color: var(--muted); font-size: 0.925rem; line-height: 1.45; }
  label { display: block; font-size: 0.8rem; margin-bottom: 0.35rem; color: var(--muted); }
  input {
    width: 100%;
    margin-bottom: 0.9rem;
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    font-size: 1rem;
  }
  button {
    width: 100%;
    margin-top: 0.35rem;
    padding: 0.7rem 1rem;
    border: 0;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
  }
  .error {
    background: color-mix(in srgb, var(--danger) 18%, transparent);
    color: var(--danger);
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  code { font-size: 0.8em; word-break: break-all; }
  .meta { font-size: 0.8rem; margin-top: 1rem; }
</style>
{% endblock %}

{% block body %}
<div class="card">
  <p class="brand">Tadaaa</p>
  <h1>Authorize MCP access</h1>
  <p>
    <strong>{{ clientName }}</strong> wants to access your todos via MCP.
    Redirect: <code>{{ redirectHost }}</code>
  </p>
  {% if error %}
    <div class="error">{{ error }}</div>
  {% endif %}
  <form method="post" action="{{ path('oauth_authorize') }}">
    <input type="hidden" name="form_token" value="{{ formToken }}">
    <label for="email">Email</label>
    <input id="email" name="email" type="email" autocomplete="username" required>
    <label for="password">Password</label>
    <input id="password" name="password" type="password" autocomplete="current-password" required>
    <button type="submit">Authorize</button>
  </form>
  <p class="meta">Resource: <code>{{ mcpResource }}</code></p>
</div>
{% endblock %}
